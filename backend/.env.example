# Backend template only. Never commit real service-role, database, or AI keys.
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
# Optional legacy alias: SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
AI_PROVIDER=groq
AI_MODEL=llama-3.3-70b-versatile
ENABLE_QUESTION_SCREENSHOTS=false
SCREENSHOT_MODE=on_demand
PAPER_CHECKER_DELETE_UPLOAD_AFTER_REPORT=true
PAPER_CHECKER_UPLOAD_RETENTION_HOURS=24
XAI_API_KEY=
XAI_MODEL=grok-3-mini
GEMINI_API_KEY=
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_MODEL=gemini-2.5-flash-lite
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4.1-mini
PORT=3001
AUTO_PROCESS_RESOURCES=true
RESOURCE_QUEUE_INTERVAL_MS=15000
RESOURCE_PROCESSING_MAX_CONCURRENCY=2
BULK_UPLOAD_MAX_CONCURRENCY=3
BULK_DETECTION_MAX_CONCURRENCY=3
BULK_DETECTION_TIMEOUT_SECONDS=20
BULK_DETECTION_PAGE_LIMIT=3
CORS_ORIGIN=http://localhost:5173
NODE_ENV=development
LOG_LEVEL=info

# Optional legacy ingestion / Drizzle tooling
OPENAI_CHAT_MODEL=
OPENAI_EMBEDDING_MODEL=
DATABASE_URL=
