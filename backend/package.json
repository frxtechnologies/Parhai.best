{
  "name": "parhai-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -b",
    "start": "node dist/index.js",
    "test": "tsx --test src/**/*.test.ts",
    "generate:screenshots": "tsx src/scripts/generate-question-screenshots.ts",
    "audit:questions": "tsx src/scripts/audit-question-index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@napi-rs/canvas": "^0.1.80",
    "@supabase/realtime-js": "^2.108.2",
    "@supabase/supabase-js": "^2.108.2",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "multer": "^2.2.0",
    "pdf-parse": "^1.1.1",
    "pdfjs-dist": "^5.4.624",
    "pino": "^9.14.0",
    "pino-http": "^10.5.0",
    "serverless-http": "^4.0.0",
    "ws": "^8.21.0",
    "zod": "^3.25.20"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.15.3",
    "@types/pdf-parse": "^1.1.5",
    "@types/ws": "^8.18.1",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.19.4",
    "typescript": "^5.9.2"
  }
