# Parhai.com environment variable index. Keep real values out of Git.

# frontend/.env
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
# Optional legacy alias: VITE_SUPABASE_ANON_KEY=
# Leave blank on Netlify to use the same-origin /.netlify/functions API.
VITE_API_URL=

# backend/.env
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
# Optional legacy alias: SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
AI_PROVIDER=xai
XAI_API_KEY=
XAI_MODEL=grok-3-mini
GEMINI_API_KEY=
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_MODEL=gemini-2.5-flash-lite
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4.1-mini
PORT=3001
CORS_ORIGIN=http://localhost:5173
NODE_ENV=development
LOG_LEVEL=info

# Question screenshot rendering
ENABLE_QUESTION_SCREENSHOTS=false
SCREENSHOT_MODE=on_demand
