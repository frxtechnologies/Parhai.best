# Parhai.com environment variable index. Keep real values out of Git.

# frontend/.env
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
# Optional legacy alias: VITE_SUPABASE_ANON_KEY=
# Leave blank on Netlify to use the same-origin /.netlify/functions API.
VITE_API_URL=

# backend/.env
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
# Optional legacy alias: SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
GEMINI_API_KEY=
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_MODEL=gemini-2.5-flash-lite
PORT=3001
CORS_ORIGIN=http://localhost:5173
NODE_ENV=development
LOG_LEVEL=info

# Optional legacy ingestion / Drizzle tooling
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=
OPENAI_EMBEDDING_MODEL=
DATABASE_URL=
